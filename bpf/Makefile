# Build the Triade XDP relay BPF program.
#
#   make            # builds triade_xdp.bpf.o
#   make clean
#
# Requires: clang >= 14, libbpf-dev (for <bpf/bpf_helpers.h>), bpftool.
# On Debian/Ubuntu/Proxmox:  apt install clang libbpf-dev linux-tools-common

CLANG     ?= clang
ARCH      := $(shell uname -m | sed 's/x86_64/x86/;s/aarch64/arm64/')
TARGET    := triade_xdp.bpf.o
SRC       := triade_xdp.bpf.c

# vmlinux.h is generated by `bpftool btf dump file /sys/kernel/btf/vmlinux \
#   format c > vmlinux.h` if the program ever needs kernel types. The current
# relay is minimal and doesn't need it.

BPF_CFLAGS := -O2 -g -target bpf -D__TARGET_ARCH_$(ARCH) \
	      -Wall -Werror \
	      -I/usr/include/$(shell uname -m)-linux-gnu

all: $(TARGET)

$(TARGET): $(SRC)
	$(CLANG) $(BPF_CFLAGS) -c $< -o $@

clean:
	rm -f $(TARGET)

.PHONY: all clean
